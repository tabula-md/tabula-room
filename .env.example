# HTTP and Socket.IO port.
PORT=3002

# Comma-separated browser origin allowlist.
# If unset, localhost origins are allowed for local development.
TABULA_ROOM_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local encrypted snapshot storage directory.
TABULA_ROOM_DATA_DIR=.tabula-room/data

# Maximum HTTP JSON body, Socket.IO packet, and encrypted ciphertext bytes.
TABULA_ROOM_MAX_PAYLOAD_BYTES=1048576

# In-memory per-minute limit for snapshot writes, socket connections, room joins, and room messages.
TABULA_ROOM_RATE_LIMIT_PER_MINUTE=600
