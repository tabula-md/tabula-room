{
  "name": "tabula-room",
  "version": "0.1.0",
  "description": "Encrypted collaboration room server for Tabula.md.",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:watch": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "pr:body": "node scripts/pr-body.mjs",
    "pr:handoff": "node scripts/pr-handoff.mjs",
    "pr:metadata": "node scripts/pr-metadata.mjs",
    "pr:ready": "node scripts/pr-ready.mjs",
    "pr:title": "node scripts/pr-title.mjs",
    "labels:sync": "node scripts/sync-labels.mjs",
    "knowledge:check": "node scripts/knowledge-check.mjs",
    "workflow:doctor": "node scripts/workflow-doctor.mjs",
    "workflow:maintenance": "node scripts/workflow-maintenance.mjs",
    "workflow:status": "node scripts/workflow-status.mjs",
    "workflow:sync": "node scripts/workflow-sync.mjs",
    "test:hooks": "node scripts/test-codex-hooks.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^26.0.0",
    "@types/supertest": "^6.0.2",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
